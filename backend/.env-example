# ─── Application ─────────────────────────────────────────────────────────────
# Server port. Defaults to 3000.
PORT=3000

# Runtime environment. Options: development | production | test
NODE_ENV=development

# Phone encryption key (AES-256-GCM). Must be exactly 32 bytes encoded as base64.
# Run `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"` to generate a new one.
PHONE_ENCRYPTION_KEY=C2IN/vFuzFIYJeEElsvj9BUQ/MN1Yss2KYuhYg/ROo4=

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Local setup: create a DB named "pupzy" and update credentials below.
DATABASE_URL=postgresql://postgres:password@localhost:5432/pupzy

# Connection pool settings (optional — defaults shown)
# Max simultaneous connections to PostgreSQL.
DB_POOL_MAX=20
# Release idle connections after N milliseconds.
DB_IDLE_TIMEOUT_MS=30000
# Fail if acquiring a connection takes longer than N milliseconds.
DB_CONNECTION_TIMEOUT_MS=2000

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Get these values from:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# Copy the values from the downloaded JSON file:
#   "project_id"   → FIREBASE_PROJECT_ID
#   "client_email" → FIREBASE_CLIENT_EMAIL
#   "private_key"  → FIREBASE_PRIVATE_KEY (keep the \n escape sequences)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# For Flutter web: set to your web app origin.
# For Flutter mobile: leave empty (mobile apps don't need CORS).
# Example: "https://app.pupzy.com,http://localhost:3000"
ALLOWED_ORIGINS=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum number of requests per window per IP address.
THROTTLE_LIMIT=100
# Time window in milliseconds.
THROTTLE_TTL_MS=60000
